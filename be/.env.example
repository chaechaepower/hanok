# ========================
# Spring 프로파일
# ========================
SPRING_PROFILES_ACTIVE=dev        # prod 환경에서는 prod로 변경

# ========================
# DB 설정
# ========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_db_name
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ========================
# JWT 설정
# ========================
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=3600000            # 1시간 (ms)
JWT_REFRESH_EXPIRATION=604800000  # 7일 (ms)

# ========================
# 추후 추가 예정
# ========================
# Redis
# REDIS_HOST=
# REDIS_PORT=

# GCS
# GCS_BUCKET_NAME=
# GCS_CREDENTIALS=

# OpenVidu
# OPENVIDU_URL=
# OPENVIDU_SECRET=

# PortOne
# PORTONE_API_KEY=
# PORTONE_API_SECRET=
